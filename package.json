{
  "name": "where-to-visit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "node scripts/run-with-supabase-target.mjs local -- next dev",
    "dev:remote": "node scripts/run-with-supabase-target.mjs remote -- next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "test:e2e": "npm run test:e2e:local",
    "test:e2e:local": "node scripts/run-with-supabase-target.mjs local -- playwright test",
    "test:e2e:remote": "node scripts/run-with-supabase-target.mjs remote -- playwright test",
    "supabase:start": "node scripts/supabase-local-stack.mjs start",
    "supabase:stop": "node scripts/supabase-local-stack.mjs stop",
    "supabase:status": "node scripts/supabase-local-stack.mjs status",
    "supabase:migration:list": "node scripts/supabase-local-command.mjs migration list --local",
    "supabase:migration:up": "node scripts/supabase-local-command.mjs migration up --local",
    "supabase:db:reset": "node scripts/supabase-local-command.mjs db reset --local --no-seed",
    "supabase:db:advisors": "node scripts/supabase-local-command.mjs db advisors --local --type all --level warn --fail-on warn",
    "supabase:db:advisors:all": "node scripts/supabase-local-command.mjs db advisors --local --type all --level info",
    "supabase:test:db": "node scripts/supabase-local-command.mjs test db --local",
    "supabase:db:query": "node scripts/supabase-local-command.mjs db query --local",
    "test:supabase:wrappers": "node --test scripts/tests/*.test.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "supabase": "2.109.1",
    "typescript": "6.0.3"
  }
}
